# Unified Offline Operations Portal — environment variables.
#
# Copy to `.env` before running `docker compose up` (the start.sh
# script does this for you). Every value shown here is a safe demo
# default — rotate ENC_KEYS and ADMIN_PASSWORD before any real
# deployment.

# --- Postgres ----------------------------------------------------------
POSTGRES_USER=oops
POSTGRES_PASSWORD=oops
POSTGRES_DB=oops
DB_PORT=5432

# --- Backend -----------------------------------------------------------
BACKEND_PORT=8080

# At-rest encryption keys. Format: "version:hex64[,version:hex64...]".
# The highest version is used for new writes. REQUIRED for production —
# the backend refuses to start with an empty or placeholder value unless
# OOPS_DEV_MODE=1 (see below). Generate a random key with the bundled
# keygen binary:
#
#   docker compose run --rm --entrypoint /app/keygen backend
#
# or, on a workstation with Go installed:
#
#   go run ./backend/cmd/keygen
#
# Then paste the emitted "1:<hex64>" line after the `=` below.
ENC_KEYS=

# Set to 1 to permit an ephemeral in-memory AES key when ENC_KEYS is
# empty. Intended for local demos only; the server refuses to start in
# production without ENC_KEYS unless this flag is set. Data encrypted
# under the ephemeral key is NOT recoverable after a restart.
OOPS_DEV_MODE=1

# Password assigned to the seeded `admin` user on first boot. Must be
# at least 10 characters.
ADMIN_PASSWORD=AdminTest123!

# When set to 1, the seed step also creates frontdesk / labtech /
# dispatch / analyst demo accounts (see README "Seeded Credentials").
# Defaults to 0 because the demo passwords are published in the README;
# set to 1 only for local evaluation, never for real deployments.
SEED_DEMO_USERS=0

# --- Frontend ----------------------------------------------------------
FRONTEND_PORT=3000
